{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yokry-he/yk-3d-pet/schemas/pet-manifest.schema.json",
  "title": "yk-3d-pet manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "speciesId", "rendererId", "preset", "capabilities", "files"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "speciesId": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "rendererId": { "type": "string", "minLength": 1 },
    "preset": { "enum": ["generic", "yk-pets"] },
    "capabilities": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "files": {
      "type": "object",
      "required": ["definition", "rig", "actions", "rendererAdapter"],
      "properties": {
        "definition": { "type": "string" },
        "rig": { "type": "string" },
        "actions": { "type": "string" },
        "rendererAdapter": { "type": "string" }
      }
    }
  }
}
