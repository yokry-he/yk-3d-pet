{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yokry-he/yk-3d-pet/schemas/build-pet-request.schema.json",
  "title": "BuildPetRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["operation", "speciesId"],
  "properties": {
    "operation": { "enum": ["create-pet", "add-action", "edit-rig", "edit-symbol", "validate-pet"] },
    "speciesId": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "petName": { "type": "string", "minLength": 1, "maxLength": 80 },
    "preset": { "enum": ["generic", "yk-pets"] },
    "visualStyle": { "enum": ["procedural-cute", "robot", "organic", "glb"] },
    "referenceImages": { "type": "array", "items": { "type": "string" }, "maxItems": 8 },
    "palette": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" } },
    "requiredParts": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "requiredActions": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "idleActions": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "chestSymbol": { "type": "object" },
    "backSymbol": { "type": "object" },
    "constraints": { "type": "array", "items": { "type": "string" } }
  }
}
