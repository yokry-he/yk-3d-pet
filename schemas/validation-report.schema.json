{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yokry-he/yk-3d-pet/schemas/validation-report.schema.json",
  "title": "yk-3d-pet validation report",
  "type": "object",
  "required": ["ok", "errors", "warnings", "checks"],
  "properties": {
    "ok": { "type": "boolean" },
    "errors": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "checks": { "type": "array", "items": { "type": "object", "required": ["id", "ok"], "properties": { "id": { "type": "string" }, "ok": { "type": "boolean" }, "message": { "type": "string" } } } }
  }
}
